# target settings
msgid "targetSettings.title"
msgstr "編集するマテリアルを設定"

msgid "targetSettings.mode.label"
msgstr "モード"

msgid "targetSettings.mode.singleMaterial"
msgstr "1つを編集"

msgid "targetSettings.mode.singleMaterial.help"
msgstr "1つのマテリアルを編集します。必要なときだけ、一部の使用箇所を除外できます。"

msgid "targetSettings.mode.bulkMaterials"
msgstr "複数をまとめて編集"

msgid "targetSettings.mode.bulkMaterials.help"
msgstr "複数のマテリアルへ同じ編集内容を一括適用します。質感や設定を揃えたいときに便利です。"

msgid "targetSettings.mode.slotTargets"
msgstr "マテリアルスロットで指定"

msgid "targetSettings.mode.slotTargets.help"
msgstr "マテリアルではなく、マテリアルスロットごとに編集対象を指定します。\n使用箇所ごとに編集したい場合や、パスで指定したいときに便利です。\n複数のマテリアルスロットをまとめて指定でき、それぞれに同じ編集内容が適用されます。アニメーションなどで1つのスロットに複数のマテリアルが割り当てられる場合も、それらすべてに同じ編集内容が適用されます。"

msgid "targetSettings.mode.allMaterials"
msgstr "すべてをまとめて編集"

msgid "targetSettings.mode.allMaterials.help"
msgstr "すべてのマテリアルへ同じ編集内容を一括適用します。質感や設定を揃えたいときに便利です。"

msgid "targetSettings.material.label"
msgstr "マテリアル"

msgid "targetSettings.materials.label"
msgstr "マテリアル"

msgid "targetSettings.slotTargets.label"
msgstr "マテリアルスロット"

msgid "targetSettings.exclusions.use"
msgstr "除外する"

msgid "targetSettings.exclusions.useSlots"
msgstr "一部の使用箇所を除外"

msgid "targetSettings.exclusions.useSlots.help"
msgstr "対象のマテリアルが複数箇所で使われている場合は、除外することで一部だけに編集を適用できます。"

msgid "targetSettings.exclusions.materials"
msgstr "除外するマテリアル"

msgid "targetSettings.exclusions.slots"
msgstr "除外する場所"

msgid "targetSettings.exclusions.objects"
msgstr "除外する GameObject"

msgid "targetSettings.exclusions.selectUsageSlots"
msgstr "除外する使用箇所を選択"

msgid "targetSettings.slotTargets.add.title"
msgstr "一括追加"

msgid "targetSettings.slotTargets.add.byGameObject"
msgstr "GameObject 以下のマテリアルスロット"

msgid "targetSettings.slotTargets.add.byMaterial"
msgstr "マテリアルの使用箇所"

msgid "targetSettings.slotTargets.add.help"
msgstr "マテリアルやメッシュを複数選択し、ここにドラッグ&ドロップすることでも一括追加できます。"

# editor
msgid "editor.title"
msgstr "マテリアルを編集"

msgid "editor.help"
msgstr "ここではマテリアルを非破壊的に編集できます。\n編集内容は自動記録され、このコンポーネントに保存されます。"

msgid "editor.noAvatarRoot.help"
msgstr "このコンポーネントは現在無効化されています。\nアバター以下にある場合のみ有効です。"

msgid "editor.notEffective.help"
msgstr "このコンポーネントは現在無効化されています。\nコンポーネントのチェックボックスがオフ、または EditorOnly の場合は適用されません。"

msgid "editor.noMaterialSelected.help"
msgstr "編集対象のマテリアルが見つかりません。上部から設定してください。"

msgid "editor.recordingSourceMaterial"
msgstr "表示用のマテリアル"

# override settings
msgid "overrideSettings.count"
msgstr "保存された編集内容: {0}箇所"

msgid "overrideSettings.help"
msgstr "保存された編集内容がここに表示されます。\n上部のマテリアル編集で自動反映されるため、通常はここを直接編集する必要はありません。\nプレビュー時やビルド時に、この編集内容がマテリアルに適用されます。"

msgid "overrideSettings.properties"
msgstr "プロパティ"

msgid "overrideSettings.reset"
msgstr "リセット"

# override utility
msgid "overrideUtility.title"
msgstr "補助ツール"

msgid "overrideUtility.replaceTexture.title"
msgstr "テクスチャを置き換える"

msgid "overrideUtility.replaceTexture.source"
msgstr "置き換えるテクスチャ"

msgid "overrideUtility.replaceTexture.destination"
msgstr "新しく使うテクスチャ"

msgid "overrideUtility.materialDiff.title"
msgstr "マテリアルの変更点を取り込む"

msgid "overrideUtility.materialDiff.original"
msgstr "元のマテリアル"

msgid "overrideUtility.materialDiff.modified"
msgstr "変更後のマテリアル"

msgid "overrideUtility.variantDiff.title"
msgstr "マテリアルバリアントの変更点を取り込む"

msgid "overrideUtility.variantDiff.material"
msgstr "マテリアルバリアント"

msgid "overrideUtility.variantDiff.notVariant"
msgstr "選択したマテリアルはマテリアルバリアントではありません。"

msgid "overrideUtility.addChanges"
msgstr "変更点を取り込む"

msgid "overrideUtility.addChangesExcludeTexture"
msgstr "変更点を取り込む（テクスチャを除く）"

