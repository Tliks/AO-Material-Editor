# target settings
msgid "targetSettings.title"
msgstr "Set Materials to Edit"

msgid "targetSettings.mode.label"
msgstr "Mode"

msgid "targetSettings.mode.singleMaterial"
msgstr "Edit One"

msgid "targetSettings.mode.singleMaterial.help"
msgstr "Edit a single material. If needed, you can exclude specific usage slots."

msgid "targetSettings.mode.bulkMaterials"
msgstr "Edit Multiple"

msgid "targetSettings.mode.bulkMaterials.help"
msgstr "Apply the same edits to multiple materials at once.\nThis is useful when you want to match their appearance and settings."

msgid "targetSettings.mode.slotTargets"
msgstr "Specify by Material Slot"

msgid "targetSettings.mode.slotTargets.help"
msgstr "Specify targets by material slot instead of by material.\nThis is useful when you want to edit by usage location or specify targets by path.\nYou can select multiple material slots at once, and the same edits will be applied to each of them. If a single slot can contain multiple materials, such as through animation, the same edits will be applied to all of them."

msgid "targetSettings.mode.allMaterials"
msgstr "Edit All"

msgid "targetSettings.mode.allMaterials.help"
msgstr "Apply the same edits to all materials at once.\nThis is useful when you want to match their appearance and settings."

msgid "targetSettings.material.label"
msgstr "Material"

msgid "targetSettings.materials.label"
msgstr "Materials"

msgid "targetSettings.slotTargets.label"
msgstr "Material Slots"

msgid "targetSettings.exclusions.use"
msgstr "Exclude"

msgid "targetSettings.exclusions.useSlots"
msgstr "Exclude Some Usage Slots"

msgid "targetSettings.exclusions.useSlots.help"
msgstr "If a target material is used in multiple slots, you can exclude some of them to apply edits only to specific ones."

msgid "targetSettings.exclusions.materials"
msgstr "Materials to Exclude"

msgid "targetSettings.exclusions.slots"
msgstr "Slots to Exclude"

msgid "targetSettings.exclusions.objects"
msgstr "GameObjects to Exclude"

msgid "targetSettings.exclusions.selectUsageSlots"
msgstr "Select Usage Slots to Exclude"

msgid "targetSettings.slotTargets.add.title"
msgstr "Bulk Add"

msgid "targetSettings.slotTargets.add.byGameObject"
msgstr "Material Slots Under GameObject"

msgid "targetSettings.slotTargets.add.byMaterial"
msgstr "Usage Slots for Material"

msgid "targetSettings.slotTargets.add.help"
msgstr "You can also bulk add by selecting multiple materials or meshes and dragging them here."

# editor
msgid "editor.title"
msgstr "Edit Materials"

msgid "editor.help"
msgstr "You can edit the material from the editing screen below.\nYour edits are recorded automatically and saved to this component."

msgid "editor.noAvatarRoot.help"
msgstr "This component is currently disabled.\nIt is only active when placed under the avatar hierarchy."

msgid "editor.notEffective.help"
msgstr "This component is currently disabled.\nIt will not be applied when the component checkbox is off or when it is set to EditorOnly."

msgid "editor.noMaterialSelected.help"
msgstr "No material to edit was found. Configure it above."

msgid "editor.recordingSourceMaterial"
msgstr "Displayed Material"

# override settings
msgid "overrideSettings.count"
msgstr "Saved Edits: {0} entries"

msgid "overrideSettings.help"
msgstr "Saved edits are shown here.\nChanges made in the normal material editing screen below are reflected automatically, so you usually do not need to edit this directly.\nThese edits are applied to the material during preview and build."

msgid "overrideSettings.properties"
msgstr "Properties"

msgid "overrideSettings.reset"
msgstr "Reset"

